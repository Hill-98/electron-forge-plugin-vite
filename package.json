{
  "name": "@hill-98/electron-forge-plugin-vite",
  "version": "1.5.2",
  "type": "module",
  "description": "vite plugin for electron forge",
  "keywords": [
    "electron",
    "forge",
    "plugin",
    "vite"
  ],
  "files": [
    "./dist",
    "./types"
  ],
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./types/vite-env.d.ts"
    },
    "./protocol-helper": {
      "types": "./types/electron-protocol-helper.d.ts",
      "import": "./dist/electron-protocol-helper.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./types/index.d.ts",
  "homepage": "https://github.com/Hill-98/electron-forge-plugin-vite",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hill-98/electron-forge-plugin-vite.git"
  },
  "bugs": "https://github.com/Hill-98/electron-forge-plugin-vite/issues",
  "author": "Zhong Lufan <lufanzhong@gmail.com>",
  "license": "MIT",
  "scripts": {
    "prepublishOnly": "npm run check && npm run test && npm run build",
    "build": "vite build",
    "check": "biome check && tsc --noEmit",
    "test": "node --experimental-test-coverage --test",
    "prepare": "husky"
  },
  "engines": {
    "node": ">= 22.0.0"
  },
  "dependencies": {
    "@electron-forge/plugin-base": "^7.11.0",
    "@electron-forge/shared-types": "^7.11.0",
    "lodash.isempty": "^4.4.0",
    "mime-types": "^3.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/lodash.isempty": "^4.4.9",
    "@types/mime-types": "^3.0.0",
    "@types/node": "latest",
    "electron": "41.0.2",
    "husky": "^9.1.6",
    "typescript": "~5.9.2",
    "vite": "^8.0.0"
  },
  "peerDependencies": {
    "@electron-forge/cli": "^7.11.0",
    "@electron-forge/core": "^7.11.0",
    "vite": "^8.0.0"
  }
}
